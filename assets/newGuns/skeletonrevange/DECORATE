//Projectiles//
ACTOR SoulRocket
{
 Projectile
 Radius 3
 Height 2
 Speed 12
 Scale 0.50
 +SEEKERMISSILE
 -RANDOMIZE
 -ROCKETTRAIL
 SeeSound "Rocket/SoulRocket"
 States
 {
 Spawn:
 TNT1 A 0 A_SeekerMissile(2,2,SMF_LOOK,128,10)
 TNT1 A 0 A_ChangeVelocity (0, random(-2, 2), 0, 1)
 BORO A 1 Bright A_SpawnItemEX("RevSmoketrail",-5,0,0)
 Loop
 Death:
 TNT1 A 0 A_SpawnItem("SoulRocketExplosion")
 TNT1 A 1
 Stop
 }
}

