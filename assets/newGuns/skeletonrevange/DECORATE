ACTOR SkeletalRevenge : Weapon
{
   Inventory.PickupSound "misc/w_pkup"
   Inventory.PickupMessage "You got the Skeletal Revenge!"
   //Weapon.UpSound "weapons/gemiup"
   Weapon.AmmoType1 "SoulRocketAmmoA"
   Weapon.AmmoType2 "RevSkullBombAmmoA"
   Weapon.AmmoGive1 20
   Weapon.AmmoGive2 5
   Weapon.AmmoUse1 1
   Weapon.AmmoUse2 1
   Weapon.SlotNumber 5
   Obituary "%o could not dodge %k's exploding bones!"
   +Weapon.Ammo_CheckBoth
   States
   {
   Spawn:
      BLPI A -1
      LOOP
   Ready:
      BOGU A 0 A_JumpIf(CountInv("SoulRocketAmmoA") == 0, "NoPrimary")
      BOGU A 0 A_JumpIf(CountInv("RevSkullBombAmmoA") == 0, "NoSecondary")
      BOGU A 1 A_WeaponReady
      Loop
    NoPrimary:
      BOGU A 1 A_WeaponReady(WRF_NOPRIMARY)
      Goto Ready
    NoSecondary:
      BOGU A 1 A_WeaponReady(WRF_NOSECONDARY)
      Goto Ready
   Deselect: 
      BOGU A 1 A_Lower
      Loop
   Select: 
      BOGU A 1 A_Raise
      Loop
   Fire:
      BOGU AABBCC 1
	  BOGU DDEF 1
	  BOGU G 1 A_FireCustomMissile("SoulRocket",0,1,0,5)
	  TNT1 A 0 A_PlaySound("Weapons/RocketFire",0,1)
      BOGU HIJ 1
      BOGU A 2
	  TNT1 A 0 A_CheckReload
      Goto Ready
	AltFire:
	  TNT1 A 0 A_Jump(16, "RevSkull")
	  BOGU AAABBBCC 1
	  BOGU DDEEFFG 1
	  TNT1 A 0 A_PlaySound("Weapons/RevSkullFire",0,1)
	  BOGU G 1 A_FireCustomMissile("RevSkullBomb",0,1,0,5)
      BOGU HHII 1 
      BOGU A 3
	  TNT1 A 0 A_CheckReload
      Goto Ready
	RevSkull:
	  BOGU AAABBBCC 1
	  BOGU DDEEFFG 1
	  TNT1 A 0 A_PlaySound("Weapons/RevSkullFire",0,1)
	  BOGU G 1 A_FireCustomMissile("RevSkull",0,1,0,5)
      BOGU HHII 1 
      BOGU A 3
	  TNT1 A 0 A_CheckReload
      Goto Ready
   }
}

